# =============================================================================
# JustFit Project - Git Ignore (Electron + Python + Vue 3)
# =============================================================================

# =============================================================================
# Old project (Wails/Go) - These should not exist in main directory
# =============================================================================
.old/
*.go
go.mod
go.sum
wails.json
app.go
main.go
internal/
frontend/wailsjs/

# =============================================================================
# Python Backend
# =============================================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist-python/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment
.env
.env.local

# =============================================================================
# Node.js / Frontend / Electron
# =============================================================================

# Dependencies
node_modules/
.pnp.*
.yarn/*
package-lock.json

# Build outputs
/frontend/dist
/frontend/dist-dev
/electron/dist
dist/
out/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Cache
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.cache
.parcel-cache
.vite/

# =============================================================================
# Electron
# =============================================================================

*.electron/
# Note: electron-builder.json is NOT ignored - it's a project file
# electron-builder.yml - alternative config, can be ignored
.npmrc

