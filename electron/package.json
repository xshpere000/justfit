{
  "name": "justfit-electron",
  "version": "0.0.3",
  "description": "JustFit Electron Main Process",
  "type": "module",
  "main": "dist/main.js",
  "author": {
    "name": "JustFit Team"
  },
  "scripts": {
    "dev": "tsc",
    "build": "tsc",
    "watch": "tsc --watch",
    "dist": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win --x64"
  },
  "build": {
    "appId": "com.justfit.app",
    "productName": "JustFit",
    "directories": {
      "output": "../dist/electron",
      "buildResources": "../resources"
    },
    "files": [
      "dist/**/*",
      "../frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../resources/backend/justfit_backend.exe",
        "to": "backend/justfit_backend.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": "x64"
        }
      ],
      "icon": "../resources/icons/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0",
    "@types/ws": "^8.5",
    "cross-env": "^7.0.3",
    "electron": "^34.0",
    "electron-builder": "^25.0",
    "typescript": "^5.7"
  },
  "dependencies": {}
}